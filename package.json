{
  "name": "@chamanbravo/jaby",
  "version": "1.0.0",
  "description": "A Redis-backed job queue for Node.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "queue",
    "job",
    "worker",
    "redis",
    "background-jobs",
    "delayed-jobs"
  ],
  "author": "chamanbravo",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ioredis": "^5.10.1"
  }
}
